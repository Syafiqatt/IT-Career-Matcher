# Salin file ini menjadi .env lalu sesuaikan nilainya.

# Server Express
PORT=3000

# Koneksi PostgreSQL
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=ganti_dengan_password_postgres_anda
PGDATABASE=career_recommender

# Alamat ML microservice (FastAPI)
ML_SERVICE_URL=http://127.0.0.1:8000

# Origin frontend yang diizinkan (CORS)
CORS_ORIGIN=http://localhost:5173

# JWT untuk autentikasi
JWT_SECRET=ganti_dengan_secret_acak_yang_kuat
JWT_EXPIRES_IN=7d
